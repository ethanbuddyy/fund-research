# 复制本文件为 settings.yaml 并填入真实 API Key：
#   cp config/settings.yaml.example config/settings.yaml
# 结构性配置（指数、权重、阈值）不是机密，可直接使用本默认值。

# ── API Key ────────────────────────────────────────────
# FRED API Key（美国宏观+巴菲特指标）。免费申请：
# https://fred.stlouisfed.org/docs/api/api_key.html
# 留空或保留占位符 → 自动降级为模拟数据（会在输出中明确标记）
# 推荐用环境变量 FRED_API_KEY 代替在此处写明文（优先级高于此处的值）
fred_api_key: "YOUR_FRED_API_KEY_HERE"

# Finnhub API Key（新闻情绪，免费注册：https://finnhub.io/）
# 留空则情绪信号退回 VIX + 标普动量推导；也可设置环境变量 FINNHUB_API_KEY
finnhub_api_key: ""

# Alpha Vantage API Key（新闻情绪 ML 打分，免费注册：https://www.alphavantage.co/support/#api-key）
# 25次/天，情绪质量优于关键词打分，配置后自动成为主要新闻来源
# 也可设置环境变量 ALPHAVANTAGE_API_KEY
alphavantage_api_key: ""

# SQLite 数据库路径（相对于项目根目录）
db_path: "data/fund_research.db"

# ── FRED 宏观序列（key 任意，值必须是真实 FRED series id）──
# 注意：GDPC1 = 实际GDP（剔除通胀），用于经济周期判断；
#       名义GDP(GDP) 会把通胀算进增长，导致周期判断系统性偏“扩张”。
fred_series:
  real_gdp: "GDPC1"          # 实际GDP（季度，链式美元）
  cpi: "CPIAUCSL"            # CPI 城市消费者
  core_cpi: "CPILFESL"       # 核心CPI
  core_pce: "PCEPILFE"       # 核心PCE物价指数（美联储真正盯的通胀指标）
  fed_funds: "FEDFUNDS"      # 联邦基金利率
  treasury_10y: "GS10"       # 10年期国债收益率
  treasury_2y: "GS2"         # 2年期国债收益率
  yield_curve_10y2y: "T10Y2Y"  # 10年-2年期限利差（衰退先行指标，日频更准）
  unemployment: "UNRATE"     # 失业率
  hy_credit_spread: "BAMLH0A0HYM2"  # 高收益债期权调整利差（独立风险因子）
  wilshire5000: "NCBEILQ027S"        # 美国非金融企业股权总市值（十亿美元，巴菲特指标分子）
  nominal_gdp: "GDP"                 # 名义GDP（十亿美元，SAAR，巴菲特指标分母）

# ── 全球宏观（World Bank + OECD，均免费无需 Key）─────────
# World Bank 提供各国 GDP增长/通胀/失业（年度，稳定）；OECD CLI 为先行指标（尽力而为）。
# 用于补足「全球QDII却只有美国宏观」的缺口，覆盖日/德/欧/英/中等基金所在区域。
global_macro:
  worldbank_indicators:
    gdp_growth: "NY.GDP.MKTP.KD.ZG"   # GDP 实际增长率(年%)
    inflation: "FP.CPI.TOTL.ZG"       # CPI 通胀(年%)
    unemployment: "SL.UEM.TOTL.ZS"    # 失业率(% 劳动力)
  regions:
    - {name: "美国",   wb: "USA", oecd: "USA"}
    - {name: "日本",   wb: "JPN", oecd: "JPN"}
    - {name: "德国",   wb: "DEU", oecd: "DEU"}
    - {name: "欧元区", wb: "EMU", oecd: "EA20"}
    - {name: "英国",   wb: "GBR", oecd: "GBR"}
    - {name: "中国",   wb: "CHN", oecd: "CHN"}
    - {name: "全球",   wb: "WLD", oecd: "OECD"}

# ── 市场指数（yfinance symbol，无需 API Key）────────────
market_indices:
  us:
    - {symbol: "^GSPC", name: "标普500"}
    - {symbol: "^IXIC", name: "纳斯达克综指"}
    - {symbol: "^DJI",  name: "道琼斯工业"}
  global:
    - {symbol: "^N225",  name: "日经225"}
    - {symbol: "^GDAXI", name: "德国DAX"}
    - {symbol: "^FTSE",  name: "英国富时100"}
    - {symbol: "^HSI",   name: "恒生指数"}
  volatility:
    - {symbol: "^VIX", name: "VIX恐慌指数"}
  commodities:
    - {symbol: "GC=F", name: "黄金期货"}
    - {symbol: "CL=F", name: "WTI原油"}

# ── 行业板块 ETF（板块趋势观察）─────────────────────────
sector_etfs:
  - {symbol: "XLK", name: "科技"}
  - {symbol: "XLV", name: "医疗"}
  - {symbol: "XLE", name: "能源"}
  - {symbol: "XLF", name: "金融"}
  - {symbol: "XLY", name: "可选消费"}
  - {symbol: "XLP", name: "必需消费"}
  - {symbol: "XLI", name: "工业"}

# ── 基金池规则筛选（开启后用规则筛选池替代硬编码核心列表）──
# 数据源：东方财富 QDII 排行。抓取失败/禁用时自动回退到 fund_universe 核心池。
fund_screener:
  enabled: true
  min_inception_years: 2.0     # 成立满 N 年
  require_3y_record: false     # 是否必须有近3年业绩
  max_purchase_fee: 0.015      # 申购费率上限(小数)，未知费率不一票否决
  per_benchmark_keep: 2        # 每个底层指数保留最优 N 只（去重，消除同质冗余）
  max_pool_size: 30            # 基金池上限
  rank_by: "return_3y"         # 组内/全局排序依据：return_1y / return_3y / return_since
  min_aum_yi: 0                # 规模下限(亿)，>0 需 pingzhongdata 富集，0=不限

# ── 基金综合评分权重（合计 = 1.0）──────────────────────
scoring_weights:
  performance: 0.30      # 类别内相对绩效（百分位排名）
  risk_adjusted: 0.25    # 类别内相对风险调整（夏普/回撤/波动百分位）
  strategy_match: 0.20   # 资产类别与当前市场信号的匹配度
  cost_efficiency: 0.15  # 费率（越低越好）
  consistency: 0.10      # 跨期收益稳定性（正收益占比 + 低离散度）

# ── 分析参数阈值 ───────────────────────────────────────
strategy_params:
  valuation_thresholds:
    cape_overvalued: 30.0    # CAPE 高估线
    cape_undervalued: 15.0   # CAPE 低估线
    pe_overvalued: 25.0      # P/E 高估线
    equity_risk_premium_threshold: 3.0  # 股权风险溢价阈值(%)
  sentiment_thresholds:
    buffett_indicator_high: 1.2   # 总市值/GDP 偏高线
    buffett_indicator_low: 0.8    # 偏低线
    vix_fear: 30                  # VIX 恐惧阈值
    vix_greed: 15                 # VIX 贪婪阈值
  cost_filter:
    max_expense_ratio: 0.015      # 可接受最高费率
    preferred_expense_ratio: 0.005  # 偏好费率

# ── 换仓阈值（防止因细微分差频繁调仓）──────────────────
rebalancing:
  score_threshold: 10    # 新推荐基金须比当前持仓高出此分数才触发换仓建议
